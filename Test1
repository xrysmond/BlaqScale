<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BlaqScale</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Cinzel:wght@400;600;900&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
  :root {
    --black:#000; --red:#9B1B2A; --red-glow:#C41230; --white:#F0EDE8;
  }

  html, body {
    width:100%; height:100%; overflow:hidden;
    background:var(--black); color:var(--white);
    font-family:'Cormorant Garamond',serif;
    -webkit-font-smoothing:antialiased;
  }

  /* ── VIEWS ── */
  .view {
    position:fixed; inset:0;
    display:flex; flex-direction:column;
    align-items:center; justify-content:center;
    opacity:0; pointer-events:none;
    transition:opacity 0.9s ease;
    z-index:10;
  }
  .view.active {
    opacity:1; pointer-events:all;
  }

  /* ────────────────────────────────────────────
     GRAIN OVERLAY (all views)
  ──────────────────────────────────────────── */
  .grain {
    position:fixed; inset:0; pointer-events:none; z-index:100;
    background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
  }

  .vignette {
    position:fixed; inset:0; pointer-events:none; z-index:99;
    background:radial-gradient(ellipse at center, transparent 45%, rgba(0,0,0,0.6) 100%);
  }

  /* ══════════════════════════════════════════
     INTRO VIEW
  ══════════════════════════════════════════ */
  #view-intro {
    background:var(--black);
    z-index:20;
  }

  .intro-ambient {
    position:absolute; top:50%; left:50%;
    transform:translate(-50%,-50%);
    width:60vw; height:60vw; max-width:500px; max-height:500px;
    background:radial-gradient(ellipse, rgba(155,27,42,0.09) 0%, transparent 65%);
    pointer-events:none;
    animation:ambientBreathe 5s ease-in-out infinite;
  }

  @keyframes ambientBreathe {
    0%,100% { opacity:0.6; transform:translate(-50%,-50%) scale(0.92); }
    50%      { opacity:1;   transform:translate(-50%,-50%) scale(1.08); }
  }

  .intro-logo {
    width:clamp(120px,30vw,180px);
    height:clamp(120px,30vw,180px);
    object-fit:contain;
    opacity:0;
    animation:logoFade 1.8s cubic-bezier(0.16,1,0.3,1) forwards 0.3s;
    margin-bottom:20px;
    position:relative; z-index:1;
  }

  @keyframes logoFade {
    0%   { opacity:0; transform:scale(0.85); filter:brightness(0); }
    60%  { opacity:1; filter:brightness(1.5); }
    100% { opacity:1; transform:scale(1); filter:brightness(1); }
  }

  .intro-brand {
    font-family:'Cinzel',serif;
    font-size:clamp(11px,2.5vw,13px);
    letter-spacing:0.7em;
    color:var(--red);
    margin-bottom:12px;
    opacity:0;
    animation:fadeUp 1s ease forwards 1.6s;
    position:relative; z-index:1;
  }

  .intro-tagline {
    font-size:clamp(18px,4vw,24px);
    font-weight:300;
    color:rgba(240,237,232,0.35);
    margin-bottom:64px;
    opacity:0;
    animation:fadeUp 1s ease forwards 1.9s;
    position:relative; z-index:1;
  }

  .intro-tagline em { color:rgba(240,237,232,0.6); font-style:normal; }

  /* CONTINUE BUTTON */
  .btn-continue {
    font-family:'Cinzel',serif;
    font-size:clamp(9px,2vw,11px);
    letter-spacing:0.55em;
    padding:18px 56px;
    background:transparent;
    color:rgba(240,237,232,0.5);
    border:1px solid rgba(155,27,42,0.35);
    cursor:pointer;
    position:relative; overflow:hidden;
    opacity:0;
    animation:fadeUp 1s ease forwards 2.4s;
    transition:color 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
    z-index:1;
  }

  .btn-continue::before {
    content:'';
    position:absolute; inset:0;
    background:var(--red);
    opacity:0;
    transition:opacity 0.4s ease;
  }

  .btn-continue:hover {
    color:var(--white);
    border-color:var(--red);
    box-shadow:0 0 50px rgba(155,27,42,0.4), 0 0 100px rgba(155,27,42,0.15);
  }

  .btn-continue:hover::before { opacity:1; }

  .btn-continue span { position:relative; z-index:1; }

  /* Pulse ring on continue */
  .btn-continue::after {
    content:'';
    position:absolute; inset:-1px;
    border:1px solid rgba(155,27,42,0.3);
    opacity:0;
    animation:ringPulse 3s ease-in-out infinite 3s;
  }

  @keyframes ringPulse {
    0%,100% { opacity:0; transform:scale(1); }
    50%      { opacity:1; transform:scale(1.04); }
  }

  /* ══════════════════════════════════════════
     MAIN VIEW — SNAP SCROLL
  ══════════════════════════════════════════ */
  #view-main {
    display:block;
    position:fixed; inset:0;
    overflow:hidden;
    opacity:0; pointer-events:none;
    transition:opacity 1.2s ease;
    z-index:10;
  }

  #view-main.active {
    opacity:1; pointer-events:all;
  }

  .snap-container {
    height:100vh;
    overflow-y:scroll;
    scroll-snap-type:y mandatory;
    -webkit-overflow-scrolling:touch;
    scrollbar-width:none;
  }

  .snap-container::-webkit-scrollbar { display:none; }

  .snap-section {
    height:100vh;
    scroll-snap-align:start;
    scroll-snap-stop:always;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    position:relative;
    padding:40px 24px;
  }

  /* Section inner — animates in on snap */
  .snap-inner {
    max-width:620px;
    width:100%;
    text-align:center;
    opacity:0;
    transform:translateY(28px);
    transition:opacity 0.85s ease, transform 0.85s cubic-bezier(0.16,1,0.3,1);
  }

  .snap-inner.visible {
    opacity:1;
    transform:translateY(0);
  }

  /* ── HERO SNAP SECTION ── */
  #snap-hero {
    justify-content:flex-start;
    padding-top:clamp(80px,13vh,150px);
    overflow:hidden;
  }

  .hero-logo-wrap {
    width:clamp(160px,42vw,240px);
    height:clamp(160px,42vw,240px);
    margin:0 auto 16px;
    position:relative;
  }

  .hero-logo-wrap::after {
    content:'';
    position:absolute; inset:-20px;
    background:radial-gradient(ellipse, rgba(155,27,42,0.2) 0%, transparent 65%);
    opacity:0;
    animation:glowPulse 3.5s ease-in-out infinite;
  }

  @keyframes glowPulse {
    0%,100% { opacity:0; }
    50%      { opacity:1; }
  }

  .hero-logo-wrap img {
    width:100%; height:100%;
    object-fit:contain; position:relative; z-index:1;
  }

  .hero-brand {
    font-family:'Cinzel',serif;
    font-size:clamp(10px,2.5vw,13px);
    letter-spacing:0.65em;
    color:var(--red);
    margin-bottom:28px;
    display:block;
  }

  .hero-headline {
    font-weight:300;
    font-size:clamp(48px,12vw,80px);
    line-height:1.04;
    margin-bottom:28px;
  }

  .hero-headline .line { display:block; overflow:hidden; }
  .hero-headline .line span { display:block; }
  .hero-headline .line:nth-child(2) span { color:var(--red); font-style:italic; }

  /* Portrait */
  .portrait-wrap {
    position:relative;
    width:clamp(160px,44vw,260px);
    margin:24px auto 0;
  }

  .portrait-wrap::before {
    content:'';
    position:absolute; inset:-1px;
    background:
      linear-gradient(var(--black), var(--black)) padding-box,
      linear-gradient(180deg, rgba(155,27,42,0.7) 0%, transparent 65%) border-box;
    border:1px solid transparent;
    -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: destination-out;
    mask-composite:exclude;
  }

  .portrait-wrap::after {
    content:'';
    position:absolute; bottom:-20px; left:50%;
    transform:translateX(-50%);
    width:80%; height:40px;
    background:radial-gradient(ellipse, rgba(196,18,48,0.65) 0%, transparent 70%);
    filter:blur(10px);
    animation:glowBreath 5s ease-in-out infinite;
  }

  @keyframes glowBreath {
    0%,100% { opacity:0.65; }
    50%      { opacity:1; }
  }

  .portrait-wrap img { width:100%; display:block; object-fit:cover; object-position:center top; }

  .portrait-fade {
    position:absolute; bottom:0; left:0; right:0;
    height:45%;
    background:linear-gradient(to bottom, transparent, var(--black));
    pointer-events:none;
  }

  .portrait-scanlines {
    position:absolute; inset:0;
    background:repeating-linear-gradient(
      0deg, transparent, transparent 3px,
      rgba(0,0,0,0.04) 3px, rgba(0,0,0,0.04) 4px
    );
    pointer-events:none; opacity:0.6;
  }

  .founder {
    font-size:clamp(15px,3.5vw,19px);
    font-weight:300; font-style:italic;
    color:rgba(240,237,232,0.4);
    line-height:1.8; margin-top:24px;
  }

  .founder strong { color:var(--white); font-style:normal; font-weight:400; }

  /* scroll cue */
  .scroll-cue {
    position:absolute; bottom:32px; left:50%; transform:translateX(-50%);
    display:flex; flex-direction:column; align-items:center; gap:8px;
  }

  .scroll-cue span {
    font-family:'Cinzel',serif; font-size:7px;
    letter-spacing:0.5em; color:rgba(240,237,232,0.15);
  }

  .scroll-dot {
    width:1px; height:36px;
    background:linear-gradient(to bottom, var(--red), transparent);
    animation:scrollPulse 2.5s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%,100% { opacity:0.2; transform:scaleY(0.6); }
    50%      { opacity:1; transform:scaleY(1); }
  }

  /* ── CONTENT SECTIONS ── */
  .section-label {
    font-family:'Cinzel',serif;
    font-size:clamp(8px,1.8vw,10px);
    letter-spacing:0.55em; color:var(--red);
    margin-bottom:28px; display:block; opacity:0.75;
  }

  .statement {
    font-size:clamp(36px,9vw,54px);
    font-weight:300; line-height:1.08; margin-bottom:32px;
    text-align:center;
  }

  .statement em { font-style:italic; color:var(--red); }

  .body-text {
    font-size:clamp(18px,4vw,21px);
    font-weight:300; line-height:1.85;
    color:rgba(240,237,232,0.55); margin-bottom:14px;
    text-align:center;
  }

  .body-text strong { color:var(--white); font-weight:400; }

  .serve-text {
    font-family:'Cinzel',serif;
    font-size:clamp(12px,2.8vw,14px);
    letter-spacing:0.3em; line-height:2.6;
    color:rgba(240,237,232,0.3); text-align:center;
  }

  .serve-text strong { color:var(--white); }

  /* Divider accent line between sections — visual only */
  .section-accent {
    width:32px; height:1px; background:var(--red);
    margin:0 auto 32px; opacity:0.4;
  }

  /* ── DECISION SECTION ── */
  #snap-decision .snap-inner { text-align:center; }

  .decision-label {
    font-family:'Cinzel',serif;
    font-size:clamp(8px,1.8vw,10px);
    letter-spacing:0.55em; color:var(--red);
    margin-bottom:28px; display:block; opacity:0.75;
  }

  .decision-line {
    font-size:clamp(28px,7vw,42px);
    font-weight:300; line-height:1.25;
    margin-bottom:52px;
    color:rgba(240,237,232,0.9);
  }

  .buttons {
    display:flex; flex-direction:column;
    gap:14px; align-items:center;
    opacity:0;
    transform:translateY(12px);
    transition:opacity 0.8s ease 0.4s, transform 0.8s cubic-bezier(0.16,1,0.3,1) 0.4s;
  }

  .buttons.visible { opacity:1; transform:translateY(0); }

  .btn {
    font-family:'Cinzel',serif;
    font-size:clamp(10px,2.5vw,11px);
    letter-spacing:0.38em; padding:19px 52px;
    text-decoration:none;
    display:inline-flex; align-items:center; justify-content:center;
    position:relative; overflow:hidden; min-width:260px;
    cursor:pointer; border:none;
    transition:box-shadow 0.4s ease, filter 0.4s ease, transform 0.2s ease;
  }

  .btn span { position:relative; z-index:1; }

  .btn::before {
    content:'';
    position:absolute; inset:0;
    opacity:0; transition:opacity 0.35s ease;
  }

  /* PRIMARY — THIS IS FOR ME */
  .btn-primary {
    background:var(--red); color:var(--white);
    border:1px solid var(--red);
  }

  .btn-primary::before { background:var(--red-glow); }

  .btn-primary:hover::before { opacity:1; }
  .btn-primary:hover {
    box-shadow:0 0 50px rgba(155,27,42,0.6), 0 0 100px rgba(155,27,42,0.25);
    filter:brightness(1.1);
  }

  .btn-primary:active { transform:scale(0.97); }

  /* GHOST — THIS ISN'T FOR ME */
  .btn-ghost {
    background:transparent;
    color:rgba(240,237,232,0.45);
    border:1px solid rgba(240,237,232,0.12);
  }

  .btn-ghost:hover {
    color:rgba(240,237,232,0.75);
    border-color:rgba(240,237,232,0.28);
    box-shadow:0 0 30px rgba(240,237,232,0.04);
  }

  .btn-ghost:active { transform:scale(0.97); }

  /* ══════════════════════════════════════════
     READY VIEW
  ══════════════════════════════════════════ */
  #view-ready {
    background:var(--black);
    z-index:30;
  }

  #view-ready .ready-ambient {
    position:absolute; top:50%; left:50%;
    transform:translate(-50%,-50%);
    width:80vw; height:80vh;
    background:radial-gradient(ellipse, rgba(155,27,42,0.08) 0%, transparent 65%);
    pointer-events:none;
    animation:ambientBreathe 4s ease-in-out infinite;
  }

  .ready-inner {
    position:relative; z-index:1;
    text-align:center; padding:40px 32px;
    max-width:680px;
  }

  .top-line {
    width:1px; height:60px;
    background:linear-gradient(to bottom, transparent, var(--red));
    margin:0 auto 40px;
    opacity:0; transform:scaleY(0); transform-origin:top;
  }

  .top-line.animate { animation:lineDown 0.8s ease forwards 0.2s; }
  @keyframes lineDown { to { opacity:1; transform:scaleY(1); } }

  .r-label {
    font-family:'Cinzel',serif;
    font-size:clamp(9px,2vw,10px);
    letter-spacing:0.55em; color:var(--red);
    margin-bottom:36px; display:block;
    opacity:0;
  }
  .r-label.animate { animation:fadeUp 1s ease forwards 0.7s; }

  .r-headline {
    font-weight:300;
    font-size:clamp(48px,12vw,78px);
    line-height:1.02; margin-bottom:40px;
  }

  .r-headline .line { display:block; overflow:hidden; }
  .r-headline .line span {
    display:block; opacity:0; transform:translateY(105%);
  }
  .r-headline .line:nth-child(1) span.animate { animation:lineReveal 1.1s cubic-bezier(0.16,1,0.3,1) forwards 0.9s; }
  .r-headline .line:nth-child(2) span.animate {
    animation:lineReveal 1.1s cubic-bezier(0.16,1,0.3,1) forwards 1.15s;
    color:var(--red); font-style:italic;
  }

  @keyframes lineReveal { to { opacity:1; transform:translateY(0); } }
  @keyframes fadeUp { from { opacity:0; transform:translateY(18px); } to { opacity:1; transform:translateY(0); } }

  .mid-line {
    width:40px; height:1px; background:var(--red);
    margin:0 auto 44px;
    opacity:0; transform:scaleX(0);
  }
  .mid-line.animate { animation:scaleIn 0.8s ease forwards 1.7s; }
  @keyframes scaleIn { to { opacity:1; transform:scaleX(1); } }

  .r-copy {
    font-size:clamp(18px,4vw,22px);
    font-weight:300; line-height:1.85;
    color:rgba(240,237,232,0.55);
    max-width:560px; margin:0 auto 48px;
    opacity:0;
  }
  .r-copy.animate { animation:fadeUp 1.2s ease forwards 1.9s; }
  .r-copy strong { color:var(--white); font-weight:400; }
  .r-copy em { color:var(--red); font-style:italic; }

  .r-btn-wrap { opacity:0; }
  .r-btn-wrap.animate { animation:fadeUp 1.2s ease forwards 2.4s; }

  .btn-wa {
    font-family:'Cinzel',serif;
    font-size:clamp(10px,2.5vw,11px);
    letter-spacing:0.38em; padding:20px 56px;
    text-decoration:none;
    display:inline-flex; align-items:center; justify-content:center;
    background:var(--red); color:var(--white);
    border:1px solid var(--red);
    position:relative; overflow:hidden;
    transition:all 0.4s ease;
  }

  .btn-wa::before {
    content:''; position:absolute; inset:0;
    background:var(--red-glow); opacity:0; transition:opacity 0.35s ease;
  }

  .btn-wa:hover::before { opacity:1; }
  .btn-wa:hover { box-shadow:0 0 50px rgba(155,27,42,0.55), 0 0 100px rgba(155,27,42,0.2); }
  .btn-wa span { position:relative; z-index:1; }

  .bottom-line {
    width:1px; height:60px;
    background:linear-gradient(to bottom, var(--red), transparent);
    margin:44px auto 0;
    opacity:0; transform:scaleY(0); transform-origin:top;
  }
  .bottom-line.animate { animation:lineDown 0.8s ease forwards 2.9s; }

  /* ══════════════════════════════════════════
     NOT-READY VIEW
  ══════════════════════════════════════════ */
  #view-notready {
    background:var(--black);
    z-index:30;
  }

  .nr-inner {
    position:relative; z-index:1;
    text-align:center; padding:40px 32px; max-width:680px;
  }

  .nr-top-line {
    width:1px; height:60px;
    background:linear-gradient(to bottom, transparent, rgba(155,27,42,0.4));
    margin:0 auto 40px;
    opacity:0; transform:scaleY(0); transform-origin:top;
  }
  .nr-top-line.animate { animation:lineDown 0.8s ease forwards 0.2s; }

  .nr-label {
    font-family:'Cinzel',serif;
    font-size:clamp(9px,2vw,10px);
    letter-spacing:0.55em; color:rgba(155,27,42,0.6);
    margin-bottom:36px; display:block; opacity:0;
  }
  .nr-label.animate { animation:fadeUp 1s ease forwards 0.7s; }

  .nr-headline {
    font-weight:300;
    font-size:clamp(48px,12vw,78px);
    line-height:1.02; margin-bottom:44px;
  }

  .nr-headline .line { display:block; overflow:hidden; }
  .nr-headline .line span {
    display:block; opacity:0; transform:translateY(105%);
  }
  .nr-headline .line:nth-child(1) span.animate {
    animation:lineReveal 1.1s cubic-bezier(0.16,1,0.3,1) forwards 0.9s;
  }
  .nr-headline .line:nth-child(2) span.animate {
    animation:lineReveal 1.1s cubic-bezier(0.16,1,0.3,1) forwards 1.15s;
    color:rgba(155,27,42,0.65); font-style:italic;
  }

  .nr-copy {
    font-size:clamp(18px,4vw,22px);
    font-weight:300; line-height:1.9;
    color:rgba(240,237,232,0.35);
    max-width:500px; margin:0 auto 52px; opacity:0;
  }
  .nr-copy.animate { animation:fadeUp 1.2s ease forwards 1.8s; }

  .nr-btn-wrap { opacity:0; }
  .nr-btn-wrap.animate { animation:fadeUp 1.2s ease forwards 2.3s; }

  .btn-prove {
    font-family:'Cinzel',serif;
    font-size:clamp(10px,2.5vw,11px);
    letter-spacing:0.35em; padding:19px 52px;
    text-decoration:none;
    display:inline-flex; align-items:center; justify-content:center;
    background:transparent; color:rgba(240,237,232,0.4);
    border:1px solid rgba(155,27,42,0.3);
    position:relative; overflow:hidden;
    transition:all 0.5s ease;
  }

  .btn-prove::before {
    content:''; position:absolute; inset:0;
    background:var(--red); opacity:0; transition:opacity 0.4s ease;
  }

  .btn-prove:hover::before { opacity:1; }
  .btn-prove:hover { color:var(--white); border-color:var(--red); box-shadow:0 0 40px rgba(155,27,42,0.4); }
  .btn-prove span { position:relative; z-index:1; }

  .nr-bottom-line {
    width:1px; height:60px;
    background:linear-gradient(to bottom, rgba(155,27,42,0.3), transparent);
    margin:44px auto 0;
    opacity:0; transform:scaleY(0); transform-origin:top;
  }
  .nr-bottom-line.animate { animation:lineDown 0.8s ease forwards 2.8s; }

  /* ══════════════════════════════════════════
     PROGRESS DOTS
  ══════════════════════════════════════════ */
  .progress-dots {
    position:fixed; right:20px; top:50%; transform:translateY(-50%);
    display:flex; flex-direction:column; gap:10px;
    z-index:50; opacity:0;
    transition:opacity 0.5s ease;
  }

  .progress-dots.visible { opacity:1; }

  .dot {
    width:4px; height:4px;
    border-radius:50%;
    background:rgba(155,27,42,0.3);
    transition:background 0.4s ease, transform 0.4s ease;
  }

  .dot.active {
    background:var(--red);
    transform:scale(1.5);
  }

  /* ══════════════════════════════════════════
     TRANSITIONS
  ══════════════════════════════════════════ */
  .transition-overlay {
    position:fixed; inset:0;
    background:var(--black);
    opacity:0; pointer-events:none;
    z-index:200;
    transition:opacity 0.5s ease;
  }

  .transition-overlay.flash {
    animation:flashIn 0.6s ease forwards;
  }

  @keyframes flashIn {
    0%   { opacity:0; }
    30%  { opacity:0.85; }
    100% { opacity:0; }
  }
</style>
</head>
<body>

<!-- PERSISTENT AUDIO -->
<audio id="amb" src="amb.mp3" loop preload="auto"></audio>

<!-- Sound FX -->
<audio id="sfx-main0" src="Main0.mp3" preload="auto"></audio>
<audio id="sfx-main1" src="Main1.mp3" preload="auto"></audio>
<audio id="sfx-r0"    src="r0.mp3"    preload="auto"></audio>
<audio id="sfx-ready1" src="ready1.mp3" preload="auto"></audio>
<audio id="sfx-notready" src="notready.mp3" preload="auto"></audio>
<audio id="sfx-decision" src="decision.mp3" preload="auto"></audio>

<div class="grain"></div>
<div class="vignette"></div>
<div class="transition-overlay" id="overlay"></div>

<!-- ══════════════════════════════════════════
     INTRO VIEW
══════════════════════════════════════════ -->
<div class="view active" id="view-intro">
  <div class="intro-ambient"></div>
  <img src="logo.jpg" alt="BlaqScale" class="intro-logo">
  <span class="intro-brand">BLAQSCALE</span>
  <p class="intro-tagline">One force. <em>All you need.</em></p>
  <button class="btn-continue" id="btn-continue">
    <span>ENTER</span>
  </button>
</div>

<!-- ══════════════════════════════════════════
     MAIN VIEW
══════════════════════════════════════════ -->
<div id="view-main">

  <!-- Progress dots -->
  <div class="progress-dots" id="progress-dots">
    <div class="dot active" data-index="0"></div>
    <div class="dot" data-index="1"></div>
    <div class="dot" data-index="2"></div>
    <div class="dot" data-index="3"></div>
    <div class="dot" data-index="4"></div>
  </div>

  <div class="snap-container" id="snap-container">

    <!-- SECTION 0: HERO -->
    <section class="snap-section" id="snap-hero">
      <div class="snap-inner" id="hero-inner">
        <div class="hero-logo-wrap">
          <img src="logo.jpg" alt="BlaqScale">
        </div>
        <span class="hero-brand">BLAQSCALE</span>
        <h1 class="hero-headline">
          <span class="line"><span>One force.</span></span>
          <span class="line"><span>All you need.</span></span>
        </h1>
        <div class="portrait-wrap">
          <img src="waeven.jpg" alt="Waeven Xrysmond">
          <div class="portrait-scanlines"></div>
          <div class="portrait-fade"></div>
        </div>
        <p class="founder">
          <strong>Waeven Xrysmond.</strong> Founder of BlaqScale.<br>
          The only man behind everything you're about to read.
        </p>
      </div>
      <div class="scroll-cue">
        <span>SCROLL</span>
        <div class="scroll-dot"></div>
      </div>
    </section>

    <!-- SECTION 1: THE TRUTH -->
    <section class="snap-section" id="snap-truth">
      <div class="snap-inner" id="truth-inner">
        <span class="section-label">THE TRUTH</span>
        <div class="section-accent"></div>
        <h2 class="statement">We don't bring leads.<br><em>We bring revenue.</em></h2>
        <p class="body-text">Most agencies hand you numbers and disappear.<br><strong>We stay until it turns into money.</strong></p>
      </div>
    </section>

    <!-- SECTION 2: THE METHOD -->
    <section class="snap-section" id="snap-method">
      <div class="snap-inner" id="method-inner">
        <span class="section-label">THE METHOD</span>
        <div class="section-accent"></div>
        <h2 class="statement">Your clients are<br>already <em>searching.</em></h2>
        <p class="body-text">They open Google. They type. Someone shows up first and gets the call.<br><strong>That someone should be you.</strong></p>
        <p class="body-text">We build the system that puts you there — and makes sure they book, not just browse.</p>
      </div>
    </section>

    <!-- SECTION 3: WHO WE WORK WITH -->
    <section class="snap-section" id="snap-who">
      <div class="snap-inner" id="who-inner">
        <span class="section-label">WHO WE WORK WITH</span>
        <div class="section-accent"></div>
        <p class="serve-text">
          <strong>PRIVATE AVIATION</strong><br>
          Brokers &amp; Operators<br><br>
          <strong>CHAUFFEUR SERVICES</strong><br><br>
          <strong>LUXURY CAR RENTAL SERVICES</strong>
        </p>
      </div>
    </section>

    <!-- SECTION 4: DECISION -->
    <section class="snap-section" id="snap-decision">
      <div class="snap-inner" id="decision-inner">
        <span class="decision-label">DECISION</span>
        <div class="section-accent"></div>
        <p class="decision-line">You've read enough.<br>You know if this is for you.</p>
        <div class="buttons" id="decision-buttons">
          <button class="btn btn-primary" id="btn-yes"><span>THIS IS FOR ME</span></button>
          <button class="btn btn-ghost"   id="btn-no"><span>THIS ISN'T FOR ME</span></button>
        </div>
      </div>
    </section>

  </div><!-- end snap-container -->
</div><!-- end view-main -->

<!-- ══════════════════════════════════════════
     READY VIEW
══════════════════════════════════════════ -->
<div class="view" id="view-ready">
  <div class="ready-ambient"></div>
  <div class="ready-inner">
    <div class="top-line" id="r-topline"></div>
    <span class="r-label" id="r-label">READY</span>
    <h1 class="r-headline">
      <span class="line"><span id="r-h1">You made</span></span>
      <span class="line"><span id="r-h2">your decision.</span></span>
    </h1>
    <div class="mid-line" id="r-midline"></div>
    <p class="r-copy" id="r-copy">
      You're a business operator.<br>
      You already know that <em>time is money.</em><br><br>
      So don't waste more of it reading.<br>
      <strong>Contact Waeven. This is the smartest move you'll make today.</strong>
    </p>
    <div class="r-btn-wrap" id="r-btnwrap">
      <a href="https://wa.me/966563194704" class="btn-wa" target="_blank"><span>WHATSAPP WAEVEN</span></a>
    </div>
    <div class="bottom-line" id="r-bottomline"></div>
  </div>
</div>

<!-- ══════════════════════════════════════════
     NOT-READY VIEW
══════════════════════════════════════════ -->
<div class="view" id="view-notready">
  <div class="nr-inner">
    <div class="nr-top-line" id="nr-topline"></div>
    <span class="nr-label" id="nr-label">NOT READY</span>
    <h1 class="nr-headline">
      <span class="line"><span id="nr-h1">As</span></span>
      <span class="line"><span id="nr-h2">expected.</span></span>
    </h1>
    <p class="nr-copy" id="nr-copy">
      You chose what most people choose.<br>
      What feels safe.<br><br>
      That's why most stay where they are.
    </p>
    <div class="nr-btn-wrap" id="nr-btnwrap">
      <button class="btn-prove" id="btn-prove"><span>PROVE OTHERWISE</span></button>
    </div>
    <div class="nr-bottom-line" id="nr-bottomline"></div>
  </div>
</div>

<script>
/* ══════════════════════════════════════════
   AUDIO ENGINE
══════════════════════════════════════════ */
const amb = document.getElementById('amb');
amb.volume = 0.5;

function playSfx(id) {
  const el = document.getElementById(id);
  if (!el) return;
  el.currentTime = 0;
  el.play().catch(()=>{});
}

function startAmb() {
  amb.play().catch(()=>{});
}

/* ══════════════════════════════════════════
   VIEW SYSTEM
══════════════════════════════════════════ */
const overlay = document.getElementById('overlay');

function flashTransition(cb) {
  overlay.style.transition = 'none';
  overlay.style.opacity = '0';
  overlay.style.pointerEvents = 'all';
  requestAnimationFrame(()=>{
    overlay.style.transition = 'opacity 0.3s ease';
    overlay.style.opacity = '0.9';
    setTimeout(()=>{
      cb();
      overlay.style.opacity = '0';
      setTimeout(()=>{ overlay.style.pointerEvents = 'none'; }, 400);
    }, 300);
  });
}

function showView(id) {
  document.querySelectorAll('.view').forEach(v => {
    v.classList.remove('active');
    v.style.display = '';
  });
  const target = document.getElementById(id);
  target.style.display = 'flex';
  requestAnimationFrame(()=> target.classList.add('active'));
}

/* ══════════════════════════════════════════
   INTRO → MAIN
══════════════════════════════════════════ */
const btnContinue = document.getElementById('btn-continue');

btnContinue.addEventListener('mouseenter', ()=>{
  playSfx('sfx-main0');
});

btnContinue.addEventListener('click', ()=>{
  playSfx('sfx-main1');
  startAmb();

  flashTransition(()=>{
    document.getElementById('view-intro').classList.remove('active');
    document.getElementById('view-intro').style.display = 'none';

    const main = document.getElementById('view-main');
    main.style.display = 'block';
    requestAnimationFrame(()=> main.classList.add('active'));

    // Trigger hero inner visible
    setTimeout(()=>{
      document.getElementById('hero-inner').classList.add('visible');
      document.getElementById('progress-dots').classList.add('visible');
    }, 400);
  });
});

/* ══════════════════════════════════════════
   SNAP SCROLL — section tracking
══════════════════════════════════════════ */
const snapContainer = document.getElementById('snap-container');
const sections = ['snap-hero','snap-truth','snap-method','snap-who','snap-decision'];
const innerIds  = ['hero-inner','truth-inner','method-inner','who-inner','decision-inner'];
const dots = document.querySelectorAll('.dot');

let currentSection = 0;
let decisionTriggered = false;

const sectionObserver = new IntersectionObserver((entries)=>{
  entries.forEach(entry => {
    if (!entry.isIntersecting) return;
    const idx = sections.indexOf(entry.target.id);
    if (idx === -1) return;

    currentSection = idx;

    // Update dots
    dots.forEach((d,i)=> d.classList.toggle('active', i === idx));

    // Animate inner
    const inner = document.getElementById(innerIds[idx]);
    if (inner) {
      setTimeout(()=> inner.classList.add('visible'), 80);
    }

    // Decision section trigger
    if (idx === 4 && !decisionTriggered) {
      decisionTriggered = true;
      playSfx('sfx-decision');
      setTimeout(()=>{
        document.getElementById('decision-buttons').classList.add('visible');
      }, 500);
    }
  });
}, { root: snapContainer, threshold: 0.55 });

sections.forEach(id => {
  const el = document.getElementById(id);
  if (el) sectionObserver.observe(el);
});

/* ══════════════════════════════════════════
   DECISION BUTTONS
══════════════════════════════════════════ */
const btnYes = document.getElementById('btn-yes');
const btnNo  = document.getElementById('btn-no');

// Hover sounds — shared r0
[btnYes, btnNo].forEach(btn => {
  btn.addEventListener('mouseenter', ()=> playSfx('sfx-r0'));
});

// YES click → READY
btnYes.addEventListener('click', ()=>{
  playSfx('sfx-ready1');
  btnYes.style.transform = 'scale(0.96)';
  setTimeout(()=>{
    flashTransition(()=>{
      document.getElementById('view-main').classList.remove('active');
      document.getElementById('view-main').style.display = 'none';
      showView('view-ready');
      triggerReadyAnims();
    });
  }, 180);
});

// NO click → NOT READY
btnNo.addEventListener('click', ()=>{
  playSfx('sfx-notready');
  btnNo.style.transform = 'scale(0.96)';
  setTimeout(()=>{
    flashTransition(()=>{
      document.getElementById('view-main').classList.remove('active');
      document.getElementById('view-main').style.display = 'none';
      showView('view-notready');
      triggerNotReadyAnims();
    });
  }, 180);
});

/* ══════════════════════════════════════════
   READY / NOT-READY ANIMATIONS
══════════════════════════════════════════ */
function triggerReadyAnims() {
  ['r-topline','r-label','r-midline','r-copy','r-btnwrap','r-bottomline'].forEach(id=>{
    const el = document.getElementById(id);
    if (el) { el.classList.remove('animate'); void el.offsetWidth; el.classList.add('animate'); }
  });
  ['r-h1','r-h2'].forEach(id=>{
    const el = document.getElementById(id);
    if (el) { el.classList.remove('animate'); void el.offsetWidth; el.classList.add('animate'); }
  });
}

function triggerNotReadyAnims() {
  ['nr-topline','nr-label','nr-copy','nr-btnwrap','nr-bottomline'].forEach(id=>{
    const el = document.getElementById(id);
    if (el) { el.classList.remove('animate'); void el.offsetWidth; el.classList.add('animate'); }
  });
  ['nr-h1','nr-h2'].forEach(id=>{
    const el = document.getElementById(id);
    if (el) { el.classList.remove('animate'); void el.offsetWidth; el.classList.add('animate'); }
  });
}

/* ══════════════════════════════════════════
   PROVE OTHERWISE → READY
══════════════════════════════════════════ */
document.getElementById('btn-prove').addEventListener('mouseenter', ()=> playSfx('sfx-r0'));
document.getElementById('btn-prove').addEventListener('click', ()=>{
  playSfx('sfx-ready1');
  flashTransition(()=>{
    document.getElementById('view-notready').classList.remove('active');
    showView('view-ready');
    triggerReadyAnims();
  });
});

/* ══════════════════════════════════════════
   INIT — hide non-active views
══════════════════════════════════════════ */
document.getElementById('view-main').style.display = 'none';
document.getElementById('view-ready').style.display = 'none';
document.getElementById('view-notready').style.display = 'none';
</script>
</body>
</html>
