<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Invoice #001 — BlaqScale</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Cinzel:wght@400;600;900&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
:root { --black:#000; --red:#9B1B2A; --white:#F0EDE8; }

html, body {
  width:100%; min-height:100%;
  background:var(--black); color:var(--white);
  font-family:'Cormorant Garamond', serif;
  -webkit-font-smoothing:antialiased;
  overflow-x:hidden;
}

.grain {
  position:fixed; inset:0; pointer-events:none; z-index:100;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
}

.ambient {
  position:fixed; top:50%; left:50%; transform:translate(-50%,-50%);
  width:80vw; height:80vh;
  background:radial-gradient(ellipse, rgba(155,27,42,0.07) 0%, transparent 65%);
  pointer-events:none; z-index:0;
  animation:ambBreathe 5s ease-in-out infinite;
}
@keyframes ambBreathe {
  0%,100%{opacity:.5;transform:translate(-50%,-50%) scale(.95)}
  50%{opacity:1;transform:translate(-50%,-50%) scale(1.05)}
}

#scan-line {
  position:fixed; left:0; right:0; height:1px;
  background:linear-gradient(90deg, transparent 0%, rgba(155,27,42,0.6) 20%, rgba(196,18,48,0.9) 50%, rgba(155,27,42,0.6) 80%, transparent 100%);
  box-shadow:0 0 12px rgba(155,27,42,0.8), 0 0 24px rgba(155,27,42,0.3);
  pointer-events:none; z-index:150; top:0; opacity:0;
}
#scan-line.run { animation:scanDown 1.4s cubic-bezier(0.4,0,0.6,1) forwards; }
@keyframes scanDown {
  0%{transform:translateY(0);opacity:0} 5%{opacity:1} 95%{opacity:1} 100%{transform:translateY(100vh);opacity:0}
}

.corner-logo {
  position:fixed; top:16px; right:16px; z-index:50;
  opacity:0; pointer-events:none; transition:opacity 0.6s ease;
}
.corner-logo.visible { opacity:1; }
.corner-logo img {
  width:38px; height:38px; object-fit:contain; display:block;
  filter:drop-shadow(0 0 6px rgba(155,27,42,0.4));
  -webkit-mask-image:radial-gradient(ellipse 68% 68% at 50% 50%, black 30%, transparent 100%);
  mask-image:radial-gradient(ellipse 68% 68% at 50% 50%, black 30%, transparent 100%);
}

.wrapper {
  position:relative; z-index:10;
  max-width:680px; width:100%;
  margin:0 auto;
  padding:80px clamp(24px,6vw,60px) 100px;
}

/* HEADER */
.inv-header {
  display:flex; justify-content:space-between; align-items:flex-start;
  margin-bottom:64px;
  opacity:0; animation:fadeUp 1s ease forwards 0.4s;
}
.inv-from {}
.inv-from-label {
  font-family:'Cinzel', serif; font-size:8px;
  letter-spacing:0.5em; color:var(--red);
  display:block; margin-bottom:10px;
  -webkit-text-stroke:0.4px var(--red);
}
.inv-from-name {
  font-size:clamp(18px,4vw,22px); font-weight:300;
  color:var(--white); line-height:1.4;
}
.inv-from-sub {
  font-size:14px; color:rgba(240,237,232,0.35);
  font-style:italic; margin-top:4px;
}

.inv-meta { text-align:right; }
.inv-num {
  font-family:'Cinzel', serif; font-size:clamp(9px,2vw,11px);
  letter-spacing:0.4em; color:var(--red);
  display:block; margin-bottom:10px;
}
.inv-date {
  font-size:14px; color:rgba(240,237,232,0.35);
  display:block; margin-bottom:4px;
}

/* DIVIDER */
.divider {
  display:block; height:1px; margin-bottom:48px;
  background:linear-gradient(90deg, rgba(155,27,42,0.95) 0%, rgba(155,27,42,0.15) 50%, transparent 100%);
  opacity:0; animation:fadeIn 1s ease forwards 0.7s;
}
@keyframes fadeIn { to{opacity:1} }

/* PARTIES */
.parties {
  display:grid; grid-template-columns:1fr 1fr;
  gap:1px; background:rgba(155,27,42,0.15);
  margin-bottom:56px;
  opacity:0; animation:fadeUp 1s ease forwards 0.8s;
}
.party { background:var(--black); padding:24px 20px; }
.party-label {
  font-family:'Cinzel', serif; font-size:8px;
  letter-spacing:0.5em; color:var(--red);
  display:block; margin-bottom:10px;
}
.party-name {
  font-size:clamp(16px,3.5vw,19px); font-weight:300;
  color:var(--white); line-height:1.4;
}
.party-sub {
  font-size:13px; color:rgba(240,237,232,0.35);
  font-style:italic; margin-top:4px;
}

/* LINE ITEMS */
.line-items {
  margin-bottom:40px;
  opacity:0; animation:fadeUp 1s ease forwards 1s;
}
.line-item {
  display:flex; justify-content:space-between; align-items:baseline;
  padding:18px 0; border-bottom:1px solid rgba(155,27,42,0.1);
  gap:20px;
}
.line-item:first-child { border-top:1px solid rgba(155,27,42,0.1); }
.item-desc {}
.item-label {
  font-size:clamp(17px,4vw,20px); font-weight:300;
  color:var(--white); display:block;
}
.item-sub {
  font-size:13px; color:rgba(240,237,232,0.35);
  font-style:italic; margin-top:4px;
}
.item-amount {
  font-size:clamp(17px,4vw,20px); font-weight:300;
  color:var(--white); white-space:nowrap; text-align:right;
}

/* TOTAL */
.total-row {
  display:flex; justify-content:space-between; align-items:baseline;
  padding:24px 0 0; gap:20px;
  opacity:0; animation:fadeUp 1s ease forwards 1.1s;
}
.total-label {
  font-family:'Cinzel', serif; font-size:clamp(9px,2vw,10px);
  letter-spacing:0.5em; color:var(--red);
  -webkit-text-stroke:0.4px var(--red);
}
.total-amount {
  font-size:clamp(28px,7vw,40px); font-weight:300;
  color:var(--white);
}
.total-amount em { font-style:italic; color:var(--red); }

/* PAYMENT */
.payment-block {
  margin-top:56px; padding:28px 24px;
  background:rgba(155,27,42,0.04);
  border:1px solid rgba(155,27,42,0.2);
  opacity:0; animation:fadeUp 1s ease forwards 1.2s;
}
.payment-title {
  font-family:'Cinzel', serif; font-size:8px;
  letter-spacing:0.5em; color:var(--red);
  display:block; margin-bottom:20px;
  -webkit-text-stroke:0.4px var(--red);
}
.payment-row {
  display:flex; justify-content:space-between; align-items:flex-start;
  padding:12px 0; border-bottom:1px solid rgba(155,27,42,0.08);
  gap:20px;
}
.payment-row:last-child { border-bottom:none; padding-bottom:0; }
.pay-label {
  font-family:'Cinzel', serif; font-size:8px;
  letter-spacing:0.4em; color:rgba(240,237,232,0.3);
  flex-shrink:0; padding-top:4px;
}
.pay-value {
  font-size:clamp(15px,3.5vw,17px); font-weight:300;
  color:var(--white); text-align:right; word-break:break-all;
  line-height:1.6;
}
.pay-value em { color:var(--red); font-style:normal; }
.wallet {
  font-size:clamp(11px,2.5vw,13px);
  color:rgba(240,237,232,0.5);
  letter-spacing:0.05em;
  line-height:1.8;
}

/* FOOTER */
.inv-footer {
  margin-top:64px; text-align:center;
  opacity:0; animation:fadeUp 1s ease forwards 1.4s;
}
.footer-note {
  font-size:clamp(15px,3.5vw,17px); font-weight:300;
  color:rgba(240,237,232,0.25); line-height:1.9;
  font-style:italic;
}

@keyframes fadeUp {
  from { opacity:0; transform:translateY(16px); }
  to   { opacity:1; transform:translateY(0); }
}
</style>
</head>
<body>

<div class="grain"></div>
<div class="ambient"></div>
<div id="scan-line"></div>
<div class="corner-logo" id="corner-logo">
  <img src="blaqscale.jpg" alt="BlaqScale">
</div>

<div class="wrapper">

  <!-- HEADER -->
  <div class="inv-header">
    <div class="inv-from">
      <span class="inv-from-label">FROM</span>
      <div class="inv-from-name">Waeven Xrysmond</div>
      <div class="inv-from-sub">BlaqScale</div>
    </div>
    <div class="inv-meta">
      <span class="inv-num">INVOICE #001</span>
      <span class="inv-date">May 2026</span>
    </div>
  </div>

  <span class="divider"></span>

  <!-- PARTIES -->
  <div class="parties">
    <div class="party">
      <span class="party-label">BILLED TO</span>
      <div class="party-name">Talha Shahzad</div>
      <div class="party-sub">Limovia Global</div>
    </div>
    <div class="party">
      <span class="party-label">FOR</span>
      <div class="party-name">Setup Fee</div>
      <div class="party-sub">One-time — campaign onboarding</div>
    </div>
  </div>

  <!-- LINE ITEMS -->
  <div class="line-items">
    <div class="line-item">
      <div class="item-desc">
        <span class="item-label">Campaign Setup & Funnel Build</span>
        <span class="item-sub">Google Ads setup, landing page, booking system integration</span>
      </div>
      <div class="item-amount">2,000 AED</div>
    </div>
  </div>

  <!-- TOTAL -->
  <div class="total-row">
    <span class="total-label">TOTAL DUE</span>
    <div class="total-amount"><em>2,000</em> AED</div>
  </div>

  <!-- PAYMENT -->
  <div class="payment-block">
    <span class="payment-title">PAYMENT DETAILS</span>
    <div class="payment-row">
      <span class="pay-label">METHOD</span>
      <div class="pay-value">Cryptocurrency — <em>USDT ERC-20</em></div>
    </div>
    <div class="payment-row">
      <span class="pay-label">WALLET</span>
      <div class="pay-value wallet">0x1F00a51223cb0a8A68476dc71BDdA6fE1C0cFBA0</div>
    </div>
    <div class="payment-row">
      <span class="pay-label">DUE</span>
      <div class="pay-value">Upon receipt</div>
    </div>
  </div>

  <!-- FOOTER -->
  <div class="inv-footer">
    <p class="footer-note">Once payment is confirmed, we start the clock.</p>
  </div>

</div>

<script>
const scanLine = document.getElementById('scan-line');
setTimeout(() => { scanLine.classList.add('run'); }, 200);
scanLine.addEventListener('animationend', () => { scanLine.style.display = 'none'; });
setTimeout(() => { document.getElementById('corner-logo').classList.add('visible'); }, 1800);
</script>
</body>
</html>
